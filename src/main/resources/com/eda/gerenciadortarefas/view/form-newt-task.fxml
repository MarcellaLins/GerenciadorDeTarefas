<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.eda.gerenciadortarefas.controller.TaskFormController">

    <!-- título principal -->
    <Label style="-fx-font-size: 18px;" text="Nova Task" />

    <!-- GRID DE CAMPOS -->
    <GridPane alignment="CENTER" hgap="10" vgap="15">
        <columnConstraints>
            <!-- Coluna dos labels -->
            <ColumnConstraints halignment="RIGHT" minWidth="80" />
            <!-- Coluna dos campos -->
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <!-- Título -->
        <Label text="Título:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="titleField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <!-- Descrição -->
        <Label text="Descrição:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextArea fx:id="descriptionField" prefRowCount="3" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <!-- Data -->
        <Label text="Prazo:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <DatePicker fx:id="datePicker" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <!-- Hora -->
        <Label text="Horário:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="timeField" promptText="14:30" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <!-- Categoria -->
        <Label text="Categoria:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <ComboBox fx:id="categoryCombo" GridPane.columnIndex="1" GridPane.rowIndex="4" />

        <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>

        <padding>
            <Insets bottom="15.0" left="100.0" right="100.0" top="15.0" />
        </padding>
    </GridPane>

    <!-- Botão Adicionar -->
    <HBox alignment="CENTER" spacing="10">
        <Button onAction="#saveTask" prefHeight="35" prefWidth="150" text="Adicionar" />
        <padding>
            <Insets bottom="20.0" top="20.0" />
        </padding>
    </HBox>

    <padding>
        <Insets bottom="50.0" top="10.0" />
    </padding>

</VBox>