<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.eda.gerenciadortarefas.controller.MainViewController"
            style="-fx-background-color: #FFFFFF;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color:#f0f0f0;">
            <padding>
                <Insets top="10" right="15" bottom="10" left="10"/>
            </padding>

            <Label fx:id="title"
                   text="Minha rotina"
                   style="-fx-font-weight:bold; -fx-font-size:15;"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <!-- Botão de filtro -->
            <MenuButton text="Filtrar"
                        style="-fx-background-radius: 10; -fx-font-weight: bold; -fx-background-color: #2d8cff;"
                        textFill="WHITE">

                <padding>
                    <Insets bottom="2" left="5" top="3"/>
                </padding>

                <items>
                    <MenuItem text="ESTUDOS" onAction="#showByCategory"/>
                    <MenuItem text="TRABALHO" onAction="#showByCategory"/>
                    <MenuItem text="CASA" onAction="#showByCategory"/>
                    <MenuItem text="FINANCAS" onAction="#showByCategory"/>
                    <MenuItem text="SAUDE" onAction="#showByCategory"/>
                    <MenuItem text="PESSOAL" onAction="#showByCategory"/>
                    <MenuItem text="MOSTRAR TUDO" onAction="#showAllTasks"/>
                </items>
            </MenuButton>

            <!-- Botão adicionar -->
            <Button text="Adicionar"
                    onAction="#openNewTask"
                    style="-fx-background-radius:10; -fx-background-color:#2d8cff; -fx-text-fill:white; -fx-font-weight:bold;">
                <padding>
                    <Insets bottom="6" left="15" right="15" top="6"/>
                </padding>
            </Button>

        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <content>

                <!-- Container dinâmico (será limpo pelo controller) -->
                <VBox fx:id="taskList" spacing="10">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                </VBox>

            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              prefHeight="50"
              style="-fx-background-color: #2d8cff;">

            <children>

                <Button text="Pendentes"
                        HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"
                        style="-fx-font-size:18px;
                               -fx-text-fill:white;
                               -fx-background-color: transparent;" />

                <Button fx:id="btnCompleted"
                        text="Concluídos"
                        onAction="#openCompletedTasks"
                        HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"
                        style="-fx-font-size:18px;
                               -fx-text-fill:white;
                               -fx-background-color: #1f6fd6;
                               -fx-font-weight:bold;" />

            </children>

        </HBox>
    </bottom>

</BorderPane>