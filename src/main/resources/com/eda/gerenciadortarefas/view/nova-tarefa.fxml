<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1" fx:controller="com.eda.gerenciadortarefas.controller.NovaTarefaController">

    <!-- título principal -->
    <Label style="-fx-font-size: 18px;" text="Nova tarefa" />

    <!-- GRID DE CAMPOS -->
    <GridPane alignment="CENTER" hgap="10" vgap="15">
        <columnConstraints>
            <!-- Coluna dos labels -->
            <ColumnConstraints halignment="RIGHT" minWidth="80" />
            <!-- Coluna dos campos -->
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <!-- Título -->
        <Label text="Título:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="tituloField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <!-- Descrição -->
        <Label text="Descrição:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextArea fx:id="descricao" prefRowCount="3" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <!-- Data -->
        <Label text="Prazo:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <DatePicker fx:id="prazoPicker" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <!-- Categoria -->
        <Label text="Categoria:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <ComboBox fx:id="categoriaCombo" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>
        <padding>
            <Insets bottom="50.0" left="100.0" right="100.0" top="50.0" />
        </padding>
    </GridPane>

    <!-- Botão Adicionar -->
    <HBox alignment="CENTER" spacing="10">
        <Button onAction="#salvarTarefa" prefHeight="35" prefWidth="150" text="Adicionar" />
        <padding>
            <Insets bottom="30.0" top="30.0" />
        </padding>
    </HBox>
    <padding>
        <Insets bottom="100.0" top="20.0" />
    </padding>

</VBox>