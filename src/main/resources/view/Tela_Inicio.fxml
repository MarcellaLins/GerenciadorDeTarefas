<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.com.gerenciadorDeTarefas.controller.Tela_Inicio"
            style="-fx-background-color: #FFFFFF;">

   <top>
      <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color:#f0f0f0;">
         <padding>
            <Insets top="10" right="15" bottom="10" left="10"/>
         </padding>

         <Label fx:id="title"
                text="Minha rotina"
                style="-fx-font-weight:bold; -fx-font-size:15;"/>

         <Pane HBox.hgrow="ALWAYS"/>

         <Button text="Filtrar"
                 style="-fx-background-radius:10; -fx-font-weight:bold; -fx-background-color:#2d8cff; -fx-text-fill:white;">
            <padding>
               <Insets bottom="6" left="15" right="15" top="6"/>
            </padding>
         </Button>

         <Button text="Adicionar"
                 onAction="#abrirNovaTarefa"
                 style="-fx-background-radius:10; -fx-background-color:#2d8cff; -fx-text-fill:white; -fx-font-weight:bold;">
            <padding>
               <Insets bottom="6" left="15" right="15" top="6"/>
            </padding>
         </Button>

      </HBox>
   </top>

   <center>
      <ScrollPane fitToWidth="true">
         <content>

            <VBox   fx:id="taskList"
                    spacing="10">
               <padding>
                  <Insets top="10" right="10" bottom="10" left="10"/>
               </padding>

               <Label text="Hoje"
                      style="-fx-font-weight:bold; -fx-font-size:16;"/>

               <CheckBox text="Acordar"
                         style="-fx-font-weight:bold; -fx-font-size:14;"/>

               <VBox>
                  <padding>
                     <Insets left="30"/>
                  </padding>
                  <Label text="9h00"/>
                  <Label text="Pessoal"/>
               </VBox>

               <CheckBox text="Tomar café"
                         style="-fx-font-weight:bold; -fx-font-size:14;"/>

               <VBox>
                  <padding>
                     <Insets left="30"/>
                  </padding>
                  <Label text="9h30"/>
                  <Label text="Pessoal"/>
               </VBox>

               <CheckBox text="Pilates"
                         style="-fx-font-weight:bold; -fx-font-size:14;"/>

               <VBox>
                  <padding>
                     <Insets left="30"/>
                  </padding>
                  <Label text="10h30"/>
                  <Label text="Pessoal"/>
               </VBox>

               <Label text="Amanhã"
                      style="-fx-font-size:16; -fx-font-weight:bold;"/>

               <CheckBox text="Estudar"
                         style="-fx-font-weight:bold; -fx-font-size:14;"/>

               <VBox>
                  <padding>
                     <Insets left="30"/>
                  </padding>
                  <Label text="14h00"/>
                  <Label text="Estudo"/>
               </VBox>

            </VBox>

         </content>
      </ScrollPane>
   </center>

   <bottom>
      <HBox alignment="CENTER"
            prefHeight="50"
            style="-fx-background-color: #2d8cff;">

         <children>

            <Button text="Pendentes"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    style="-fx-font-size:18px;
                           -fx-text-fill:white;
                           -fx-background-color: transparent;" />

            <Button text="Concluídos"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    style="-fx-font-size:18px;
                           -fx-text-fill:white;
                           -fx-background-color: #1f6fd6;
                           -fx-font-weight:bold;" />

         </children>

      </HBox>
   </bottom>

</BorderPane>
